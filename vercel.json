{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/index.js": {
      "includeFiles": "dist/*.html"
    }
  },
  "redirects": [
    {
      "source": "/:path*",
      "has": [{"type": "host", "value": "inventogeo.com"}],
      "destination": "https://www.inventogeo.com/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/blog/:slug",
      "destination": "/blog/:slug/index.html"
    },
    {
      "source": "/((?!assets/|blog/).*)",
      "destination": "/api/index"
    }
  ]
}